---
import BaseLayout from '../components/BaseLayout.astro';
import Sticker from '../components/Sticker.astro';
import { getCollection } from 'astro:content';

const publications = await getCollection('publications');

---
<BaseLayout title="Research" description="Publications by Aarya Vasantlal.">
  <section>
    <div class="kicker" style="margin-top: 24px;">research &middot; publications</div>
    <h1 class="page-title">
      Papers, labs, and<br/>
      <em>things being figured out.</em>
    </h1>
    <p class="hero__dek" style="margin-top: 18px; max-width: 56ch;">
      A mix of published, in-flight, and currently-being-written work. The official PI for each thread is named in their tile.
    </p>

    <!-- Publications -->
    <div style="margin-top: 56px;">
      <div class="kicker">publications</div>
      <div class="publications-grid">
        {publications.map(pub => {
          const href = pub.data.pdfUrl ?? (pub.data.doi ? `https://doi.org/${pub.data.doi}` : null);
          return (
            <article class={`tile${href ? ' tile--link' : ''}`} style="position:relative; padding: 22px 24px;">
              {href && <a href={href} target="_blank" rel="noopener noreferrer" class="tile-overlay-link" aria-label={pub.data.title} />}
              <div class="publication-layout">
                <div style="flex: 1;">
                  <div style="display:flex; align-items:center; gap: 10px; margin-bottom: 6px;">
                    <span class="meta">{pub.data.venue} &middot; {pub.data.year}</span>
                  </div>
                  <div class="tile-heading-md" style="line-height: 1.15;">
                    {pub.data.title}
                  </div>
                  <div class="tile-note" style="margin-top: 4px;">
                    {pub.data.authors}
                  </div>
                  {pub.data.note && (
                    <div class="tile-note" style="font-style:normal; color:var(--ink-2); margin-top: 12px; line-height: 1.5; max-width: 70ch;">
                      {pub.data.note}
                    </div>
                  )}
                </div>
                <div style="flex-shrink: 0;">
                  <Sticker color={pub.data.stickerColor} rotate={3}>{pub.data.status}</Sticker>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>

  </section>
</BaseLayout>
